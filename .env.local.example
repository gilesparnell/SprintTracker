# ─── Authentication (NextAuth v5 / Auth.js) ─────────────────
# Generate with: npx auth secret
AUTH_SECRET=

# Google OAuth (Google Cloud Console > APIs & Services > Credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ─── Email (Resend) ─────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# ─── ClickUp ────────────────────────────────────────────────
# ClickUp API Token (personal token starting with pk_)
# Get yours from: ClickUp Settings > Apps > API Token
CLICKUP_API_TOKEN=
